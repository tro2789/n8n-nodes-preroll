{
	"name": "n8n-nodes-preroll",
	"version": "0.2.1",
	"description": "n8n community node for PreRoll.io — podcast production management platform",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"author": {
		"name": "Trevor O'Hare",
		"email": "trevor@trevorohare.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/tro2789/n8n-nodes-preroll.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PreRollApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/PreRoll/PreRoll.node.js",
			"dist/nodes/PreRoll/PreRollTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^22.0.0",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
